# /home/hryu/.env — single env file loaded by every Hryu service.
# chmod 600, owned by hryu:hryu. Generate secrets with:
#   openssl rand -hex 32
#
# Copy to /home/hryu/.env on the server and fill in the blanks. Do NOT commit.

# === Telegram bot ===
# From @BotFather. If this leaks, /revoke and replace immediately.
TELEGRAM_BOT_TOKEN=
# Your operator chat_id — receives monitoring alerts and run summaries.
# DM the bot from your operator account once, then read journalctl -u hryu-bot
# for the chat_id.
OPERATOR_CHAT_ID=
# Public contact address shown in /privacy.
OPERATOR_CONTACT=
# Optional: hosted privacy policy URL.
PRIVACY_POLICY_URL=

# === Anthropic API ===
# REQUIRED if the `claude` CLI hasn't been logged in interactively for the
# hryu user. Without it, fit_analyzer / profile_builder / market_research
# silently degrade to heuristic fallbacks. Get one from
# https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
# Optional: override the cheapest-tier model used for high-volume calls.
# CLAUDE_SMALLEST_MODEL=haiku

# Base public URL emailer.py embeds in outgoing digest mail links.
HRYU_PUBLIC_URL=https://hryu.example.com
# State dir read/written by the bot (jobs.db, per-user profiles).
STATE_DIR=/home/hryu/state

# === Continuous search mode (recommended) ===
# When on, the bot runs an in-process search loop per onboarded user
# instead of relying on hryu-digest.timer. If you enable this, disable
# the timer so the same search doesn't run twice:
#   systemctl disable --now hryu-digest.timer
# HRYU_CONTINUOUS_MODE=1
# Optional operator pin: ONLY these chat_ids get searchers (comma-sep).
# Leave unset so every onboarded user is searched automatically (new
# ones are picked up within ~10 min).
# HRYU_CONTINUOUS_CHAT_ID=
# How often the bot re-scans the DB for newly-onboarded users (seconds).
# HRYU_CONTINUOUS_RECONCILE_S=600

# === Outbound email (digest notifications) ===
# Any SMTP relay works (Resend/Postmark/Mailgun/SES/your own postfix):
#   host smtp.resend.com / smtp.postmarkapp.com / ... port 587 STARTTLS.
HRYU_SMTP_HOST=
HRYU_SMTP_PORT=587
HRYU_SMTP_USERNAME=
HRYU_SMTP_PASSWORD=
# From: header. Falls back to HRYU_SMTP_USERNAME when empty.
HRYU_SMTP_FROM=
# starttls (default) | ssl | none
HRYU_SMTP_SECURITY=starttls
# Web-only users get at most one "new matches" email per this many
# seconds (default 72000 = 20h ≈ daily). Toggle per-user in Settings.
# HRYU_EMAIL_NOTIFY_MIN_INTERVAL_S=72000

# === Posting-click redirector ===
# Public URL fronting the bot's in-process redirect server. Caddy proxies
# /r* on hryu.example.com → 127.0.0.1:8001 → this URL is what we put in the
# Telegram inline buttons.
REDIRECT_BASE_URL=https://hryu.example.com
# HMAC secret. ≥32 random hex chars.
#   openssl rand -hex 32
REDIRECT_HMAC_SECRET=
# The bot starts the redirect listener in-process on this host:port.
# Caddy's `handle /r*` block must match REDIRECT_BIND_PORT.
REDIRECT_BIND_HOST=127.0.0.1
REDIRECT_BIND_PORT=8001

# === Misc ===
# App-level timezone (used for digest scheduling logs and any user-facing
# time formatting). Systemd timer runs in this zone independently.
TZ=Europe/Berlin
