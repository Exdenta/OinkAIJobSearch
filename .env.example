# Copy to .env and fill in
TELEGRAM_BOT_TOKEN=123456789:YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CHAT_ID=
STATE_DIR=state

# Operator chat_id receives monitoring alerts, error reports, and daily run
# summaries. Get it by DMing the bot from your operator account and reading
# bot.log for the chat_id, then paste here. Leave blank to disable monitoring
# delivery (telemetry still records into state/jobs.db).
OPERATOR_CHAT_ID=

# Public contact address shown in /privacy and referenced from docs/PRIVACY.md.
OPERATOR_CONTACT=lexsherman.official@gmail.com

# Optional: URL where the hosted privacy policy lives. When set, /privacy
# appends a link to this URL.
PRIVACY_POLICY_URL=

# Optional: chat_id used by tools/demo_ui_to_user.py when no arg is passed.
DEMO_CHAT_ID=

# View-posting redirector — analytics for "View posting ↗" button clicks.
# Telegram URL buttons aren't trackable directly, so when both vars below
# are set the bot rewrites those buttons to point at a signed local
# endpoint that logs the click before 302-ing to the actual URL. Leave
# both blank to keep raw URL buttons (no analytics).
#
# REDIRECT_BASE_URL: PUBLIC https URL fronting the bot's local server.
# Use a tunnel (cloudflared / ngrok / your own reverse proxy on a VPS).
# No trailing slash. Telegram needs HTTPS — http:// won't open.
REDIRECT_BASE_URL=
# REDIRECT_HMAC_SECRET: any random ≥32-char string. Used to sign click
# URLs so they can't be forged. Generate once with
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# and never share it.
REDIRECT_HMAC_SECRET=
# Optional: bind host/port for the local server. Default 127.0.0.1:8765.
# Don't change unless your tunnel needs a different upstream.
REDIRECT_BIND_HOST=127.0.0.1
REDIRECT_BIND_PORT=8765
